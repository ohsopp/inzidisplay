# PLC모니터-배포.sh / PLC모니터(배포).desktop 에서 선택적으로 읽음.
# 사용법: 이 파일을 복사해 PLC모니터_배포.env 로 두고 값 수정.

# --- (선택) 기동 후 브라우저로 열 주소. 비우거나 PLC_DEPLOY_OPEN_BROWSER=0 이면 브라우저 안 염.
PLC_DEPLOY_OPEN_BROWSER=https://inzidisplay-dashboard.vercel.app/

# --- (선택) 백엔드가 다른 리눅스 서버에 있을 때: SSH로 그쪽에서 start-backend-only.sh 실행
# 이 PC에서만 백엔드를 켤 거면 아래는 비워 두면 됨.
#
#PLC_DEPLOY_SSH_HOST=user@배포서버주소
#PLC_DEPLOY_SSH_OPTS=-o ConnectTimeout=15
# 원격 저장소 경로에 맞게 수정 (한 줄)
#PLC_DEPLOY_REMOTE_CMD='cd /home/simpac/inzi/inzidisplay_dashboard && ./scripts/start-backend-only.sh'
